<resources>
    <style name="Theme.StudyPulseAI" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <!-- Font family Poppins will be added later if files are provided -->
        <!-- <item name="android:fontFamily">@font/poppins</item> -->
    </style>

    <style name="ShapeAppearance.StudyPulseAI.HeaderImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">80dp</item>
    </style>

    <!-- Modern Slider Style (Perfect Circular Thumb) -->
    <style name="Widget.StudyPulseAI.Slider" parent="Widget.Material3.Slider">
        <item name="trackHeight">4dp</item>
        <item name="thumbRadius">10dp</item>
        <item name="thumbColor">@color/primary</item>
        <item name="thumbStrokeWidth">2dp</item>
        <item name="thumbStrokeColor">@color/white</item>
        <item name="trackColorActive">@color/primary</item>
        <item name="trackColorInactive">#33000000</item>
        <item name="labelBehavior">gone</item>
        <item name="haloColor">@android:color/transparent</item>
    </style>
</resources>