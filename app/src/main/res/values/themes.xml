<resources>
    <style name="Theme.StudyPulseAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="ShapeAppearance.StudyPulseAI.HeaderImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">80dp</item>
    </style>

    <style name="Widget.StudyPulseAI.Slider" parent="Widget.MaterialComponents.Slider">
        <item name="trackHeight">10dp</item>
        <item name="thumbRadius">12dp</item>
        <item name="trackColorInactive">#EEEEEE</item>
        <item name="labelBehavior">gone</item>
        <item name="haloColor">@android:color/transparent</item>
        <item name="haloRadius">0dp</item>
    </style>
</resources>
